{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": [
    "typescript",
    "unicorn",
    "oxc",
    "react"
  ],
  "categories": {
    "correctness": "error",
    "suspicious": "error",
    "pedantic": "error",
    "perf": "error"
  },
  "rules": {
    "max-lines-per-function": ["error", 75],
    "react/react-in-jsx-scope": "off"
  },
  "env": {
    "builtin": true
  }
}